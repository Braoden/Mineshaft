{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "Bash\\(gh pr create.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{MS_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash\\(git checkout -b.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{MS_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash\\(git switch -c.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{MS_BIN}} tap guard pr-workflow"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MS_SESSION_ID=${MS_SESSION_ID:-$(uuidgen)} MS_HOOK_SOURCE=startup {{MS_BIN}} prime --hook"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MS_HOOK_SOURCE=compact {{MS_BIN}} prime --hook"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "case \"${MS_ROLE:-}\" in *witness*|*refinery*|supervisor*|*boot*) exit 0 ;; *) {{MS_BIN}} mail check --inject ;; esac"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{MS_BIN}} costs record &"
          }
        ]
      }
    ]
  }
}
