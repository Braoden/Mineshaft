{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "{{MS_BIN}} tap guard pr-workflow",
        "matcher": "Shell(gh pr create*)"
      },
      {
        "command": "{{MS_BIN}} tap guard pr-workflow",
        "matcher": "Shell(git checkout -b*)"
      },
      {
        "command": "{{MS_BIN}} tap guard pr-workflow",
        "matcher": "Shell(git switch -c*)"
      }
    ],
    "sessionStart": [
      {
        "command": "{{MS_BIN}} prime --hook"
      }
    ],
    "preCompact": [
      {
        "command": "{{MS_BIN}} prime --hook"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "{{MS_BIN}} mail check --inject"
      }
    ],
    "stop": [
      {
        "command": "{{MS_BIN}} costs record &"
      }
    ]
  }
}
